# === Database ===
DATABASE_URL=postgresql://signal:signal@postgres:5432/signal_lab

# === Backend ===
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# === Sentry ===
# Get your DSN at https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:3001

# === PostgreSQL ===
POSTGRES_USER=signal
POSTGRES_PASSWORD=signal
POSTGRES_DB=signal_lab

# === Grafana ===
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_SERVER_HTTP_PORT=3100
