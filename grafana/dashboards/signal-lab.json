{
  "id": null,
  "uid": "signal-lab",
  "title": "Signal Lab Overview",
  "tags": ["signal-lab"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Scenario Runs by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (type, status) (increase(scenario_runs_total[5m]))",
          "legendFormat": "{{type}} / {{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 2,
      "title": "Scenario Run Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, type) (rate(scenario_run_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{type}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, type) (rate(scenario_run_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{type}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, type) (rate(scenario_run_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{type}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (type) (increase(scenario_runs_total{status=~\"error|validation_error\"}[5m]))",
          "legendFormat": "errors / {{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP Requests Total",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (method, path, status_code) (increase(http_requests_total[5m]))",
          "legendFormat": "{{method}} {{path}} {{status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total Scenario Runs (counters)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(scenario_runs_total)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Application Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{app=\"signal-lab\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
